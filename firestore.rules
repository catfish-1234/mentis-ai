rules_version = '2';

/**
 * Firestore Security Rules for MentisAI
 *
 * Enforces:
 * - Users can only read/write their own data under users/{uid}/*
 * - Feedback collection is write-only (no reads)
 * - All other access is denied by default
 *
 * Deploy with: firebase deploy --only firestore:rules
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // User-scoped data: chats, notes, flashcards, quizzes
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Global feedback collection: write-only, no reads
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['messageId', 'userId', 'rating', 'timestamp'])
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.rating in ['up', 'down'];
      allow read, update, delete: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
